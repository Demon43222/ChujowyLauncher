<html lang="pl">
<head>
    <meta charset="utf-8">
    <title>Chujowy Launcher</title>
    <link rel="stylesheet" href="./assets/css/amongus.css">
</head>
<body>
    <%- include('frame') %>
    <section id="loadingScreen">
        <div class="loadingCard">
            <span>Uruchamianie launchera</span>
            <h2 id="loadingTitle">Sprawdzam stan launchera...</h2>
            <div class="progressTrack">
                <div id="loadingProgressBar"></div>
            </div>
            <strong id="loadingProgressValue">0%</strong>
        </div>
    </section>
    <main id="shell" hidden>
        <section class="workspaceBand readyLaunchBand" id="readyLaunchBand" hidden>
            <div class="readyLaunchWrap">
                <button id="readyLaunchGame" class="heroLaunchButton" type="button">Graj</button>
                <section class="installedModsPanel">
                    <span>Zainstalowane mody</span>
                    <div class="installedModsList">
                        <div><button class="modNameLink" data-mod-release="mira" type="button">TOU Mira</button><span class="modVersionGroup"><em id="readyMiraVersionLabel">Brak</em><button id="readyMiraUpdateBadge" class="modUpdateBadge" data-update-mod="mira" type="button" hidden></button></span></div>
                        <div><button class="modNameLink" data-mod-release="extension" type="button">MegaChujoweExt</button><span class="modVersionGroup"><em id="readyExtensionVersionLabel">Brak</em><button id="readyExtensionUpdateBadge" class="modUpdateBadge" data-update-mod="extension" type="button" hidden></button></span></div>
                        <div><button class="modNameLink" data-mod-release="aleLudu" type="button">AleLuduMod</button><span class="modVersionGroup"><em id="readyAleLuduVersionLabel">Brak</em><button id="readyAleLuduUpdateBadge" class="modUpdateBadge" data-update-mod="aleLudu" type="button" hidden></button></span></div>
                        <div><button class="modNameLink" data-mod-release="aUnlocker" type="button">AUnlocker</button><span class="modVersionGroup"><em id="readyAUnlockerVersionLabel">Brak</em><button id="readyAUnlockerUpdateBadge" class="modUpdateBadge" data-update-mod="aUnlocker" type="button" hidden></button></span></div>
                    </div>
                    <button id="readyOpenPlugins" class="quietButton addModButton" type="button">Dodaj mod</button>
                </section>
            </div>
        </section>

        <section class="workspaceBand layoutGrid" id="setupWorkspace">
            <section class="panel simplePanel">
                <div class="panelHeader">
                    <h2>Status</h2>
                    <span id="gameStateLabel">Nie gotowe</span>
                </div>
                <div class="statusList simpleStatus">
                    <div><span>Gra</span><strong id="foundGameLabel">Nie znaleziono</strong></div>
                    <div><span>Mody</span><strong id="modsStateLabel">Do przygotowania</strong></div>
                    <div><span>Ostatnia akcja</span><strong id="lastAction">Brak</strong></div>
                </div>
                <div class="actions simpleActions">
                    <button id="autoFindGame" type="button">Znajdz gre</button>
                    <button id="installEverything" class="primary" type="button">Przygotuj wszystko</button>
                    <button id="launchGame" class="primary" type="button">Graj</button>
                    <button id="openPlugins" type="button">Dodaj mod</button>
                    <button id="selectSourceDir" type="button">Wskaz pliki recznie</button>
                </div>
            </section>

            <aside class="panel versionsPanel">
                <div class="panelHeader">
                    <h2>Wersje</h2>
                </div>
                <div class="versionList">
                    <div><button class="modNameLink" data-mod-release="mira" type="button">Mira</button><strong id="miraVersionLabel">Brak</strong><button id="miraUpdateBadge" class="modUpdateBadge" data-update-mod="mira" type="button" hidden></button></div>
                    <div><button class="modNameLink" data-mod-release="extension" type="button">Ext</button><strong id="extensionVersionLabel">Brak</strong><button id="extensionUpdateBadge" class="modUpdateBadge" data-update-mod="extension" type="button" hidden></button></div>
                    <div><button class="modNameLink" data-mod-release="aleLudu" type="button">AleLudu</button><strong id="aleLuduVersionLabel">Brak</strong><button id="aleLuduUpdateBadge" class="modUpdateBadge" data-update-mod="aleLudu" type="button" hidden></button></div>
                    <div><button class="modNameLink" data-mod-release="aUnlocker" type="button">AUnlocker</button><strong id="aUnlockerVersionLabel">Brak</strong><button id="aUnlockerUpdateBadge" class="modUpdateBadge" data-update-mod="aUnlocker" type="button" hidden></button></div>
                </div>
                <button id="toggleConsole" class="quietButton" type="button">Pokaz konsole</button>
            </aside>
        </section>

        <section class="workspaceBand">
            <section class="panel logPanel" id="consolePanel" hidden>
                <div class="panelHeader">
                    <h2>Dziennik operacji</h2>
                </div>
                <pre id="logOutput"></pre>
            </section>
        </section>
    </main>
    <div id="toast" hidden></div>
    <section id="debugMenu" hidden>
        <div class="debugMenuCard">
            <span>Debug</span>
            <h2>Wybierz ekran</h2>
            <div class="debugMenuActions">
                <button data-debug-screen="ready" type="button">Ekran Graj</button>
                <button data-debug-screen="setup" type="button">Ekran przygotowania</button>
                <button data-debug-screen="console" type="button">Konsola</button>
                <button data-debug-screen="loading" type="button">Loading screen</button>
                <button data-debug-screen="update" type="button">Aktualizacja</button>
                <button data-debug-screen="confirmSkip" type="button">Potwierdzenie odmowy</button>
            </div>
            <button id="closeDebugMenu" class="quietButton" type="button">Zamknij</button>
        </div>
    </section>
    <section id="updatePrompt" hidden>
        <div class="updatePromptCard">
            <span>Aktualizacja launchera</span>
            <h2 id="updatePromptTitle">Aktualizacja dostepna</h2>
            <p id="updatePromptMessage"></p>
            <small id="updatePromptDetail"></small>
            <div class="updatePromptActions">
                <button id="updatePromptDecline" class="dangerAction" type="button">Nie</button>
                <button id="updatePromptConfirm" class="successAction" type="button">Tak</button>
            </div>
        </div>
    </section>
    <script src="./assets/js/amongus.js"></script>
</body>
</html>
